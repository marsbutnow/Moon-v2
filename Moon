/* ── BOOT LOADING SCREEN ── */
#boot-screen{
  position:fixed;inset:0;z-index:999999;
  background:#000;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:0;
  font-family:'JetBrains Mono',monospace;
}
#boot-screen.done{opacity:0;transition:opacity .5s;pointer-events:none;}
.boot-logo{
  font-size:40px;font-weight:900;letter-spacing:4px;
  color:#7c6aff;text-shadow:0 0 30px rgba(124,106,255,.6);
  margin-bottom:6px;font-family:'Courier New',monospace;
}
.boot-sub{font-size:11px;color:#3a3a5a;letter-spacing:3px;margin-bottom:32px;}
.boot-bar-wrap{
  width:400px;max-width:90vw;height:3px;
  background:#1a1a2a;border-radius:2px;overflow:hidden;margin-bottom:16px;
}
.boot-bar{
  height:100%;background:linear-gradient(90deg,#7c6aff,#a89cff);
  width:0%;transition:width .08s linear;border-radius:2px;
}
.boot-log{
  width:400px;max-width:90vw;height:180px;overflow:hidden;
  display:flex;flex-direction:column;justify-content:flex-end;gap:2px;
  padding:8px 0;
}
.boot-line{
  font-size:10px;color:#2a2a4a;letter-spacing:.5px;
  display:flex;gap:8px;line-height:1.6;
  animation:bootfade .1s ease both;
}
.boot-line.active{color:#a89cff;}
.boot-line.done{color:#3a5a3a;}
.boot-line .bl-status{flex-shrink:0;width:14px;}
.boot-line .bl-path{color:#4a4a6a;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.boot-line .bl-size{color:#2a2a4a;flex-shrink:0;}
.boot-line.done .bl-path{color:#4a8a4a;}
.boot-line.done .bl-size{color:#4a8a4a;}
.boot-pct{font-size:11px;color:#5a5a8a;letter-spacing:2px;margin-top:4px;}
@keyframes bootfade{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:none;}}


@keyframes moonFloat{
  0%,100%{transform:translateY(0) rotate(0deg);filter:drop-shadow(0 0 40px rgba(180,190,220,.35)) drop-shadow(0 0 80px rgba(120,140,200,.2));}
