/* ── LOGIN MODAL ── */
#login-modal{position:fixed;inset:0;z-index:9500;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;}
#login-modal.open{display:flex;}
.lm-box{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:36px 32px 28px;width:320px;display:flex;flex-direction:column;gap:14px;box-shadow:0 24px 60px rgba(0,0,0,.6);}
.lm-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--a2);text-align:center;letter-spacing:-.3px;}
.lm-sub{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);text-align:center;letter-spacing:1px;}
.lm-inp{background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;padding:10px 14px;border-radius:9px;outline:none;width:100%;transition:border-color .2s;}
.lm-inp:focus{border-color:var(--a);}
.lm-inp.bad{border-color:#e63946;animation:shake .35s ease;}
.lm-btn{background:var(--a);border:none;color:#fff;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;padding:11px;border-radius:9px;cursor:pointer;transition:opacity .15s,transform .15s;}
.lm-btn:hover{opacity:.85;transform:translateY(-1px);}
.lm-err{font-family:'JetBrains Mono',monospace;font-size:10px;color:#e63946;text-align:center;min-height:14px;letter-spacing:.5px;}
#login-btn{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'JetBrains Mono',monospace;font-size:10px;padding:5px 13px;border-radius:20px;cursor:pointer;transition:all .15s;letter-spacing:1px;flex-shrink:0;}
#login-btn:hover{border-color:var(--a);color:var(--a2);}
#user-badge{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--a2);padding:4px 10px;background:rgba(124,106,255,.1);border:1px solid var(--border);border-radius:20px;display:none;align-items:center;gap:6px;flex-shrink:0;}
#user-badge.show{display:flex;}
#user-badge .ub-role{color:var(--dim);font-size:9px;}
#logout-btn{background:none;border:none;cursor:pointer;color:var(--dim);font-size:12px;padding:0 2px;line-height:1;transition:color .15s;}
#logout-btn:hover{color:#e63946;}
#home-topbar{position:absolute;top:0;left:0;right:0;z-index:10;padding:12px 20px;display:flex;align-items:center;gap:10px;background:linear-gradient(to bottom,rgba(0,0,0,.5),transparent);}
#home-user-badge{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--a2);display:none;align-items:center;gap:6px;}
#home-user-badge.show{display:flex;}
#login-btn-home{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'JetBrains Mono',monospace;font-size:10px;padding:5px 13px;border-radius:20px;cursor:pointer;transition:all .15s;letter-spacing:1px;}
#login-btn-home:hover{border-color:var(--a);color:var(--a2);}
/* ── GLOBAL CHAT ── */
#chat-btn{position:fixed;bottom:24px;right:24px;z-index:4000;width:48px;height:48px;border-radius:50%;background:var(--a);border:none;cursor:pointer;display:none;align-items:center;justify-content:center;font-size:20px;box-shadow:0 4px 20px rgba(0,0,0,.4);transition:transform .15s,box-shadow .15s;}
#chat-btn.show{display:flex;}
#chat-btn:hover{transform:scale(1.1);box-shadow:0 6px 28px rgba(0,0,0,.5),0 0 16px var(--glow);}
#chat-unread{position:absolute;top:-3px;right:-3px;width:16px;height:16px;border-radius:50%;background:#e63946;color:#fff;font-family:'JetBrains Mono',monospace;font-size:9px;display:none;align-items:center;justify-content:center;border:2px solid var(--bg);}
#chat-unread.show{display:flex;}
#chat-panel{position:fixed;bottom:82px;right:24px;z-index:4000;width:320px;height:430px;background:var(--bg2);border:1px solid var(--border);border-radius:16px;display:none;flex-direction:column;box-shadow:0 12px 40px rgba(0,0,0,.5);overflow:hidden;}
#chat-panel.open{display:flex;animation:chatPop .2s cubic-bezier(.22,1,.36,1);}
@keyframes chatPop{from{opacity:0;transform:translateY(12px) scale(.96);}to{opacity:1;transform:none;}}
#chat-head{padding:12px 14px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0;}
#chat-head-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text);flex:1;}
#chat-online{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--a3);letter-spacing:1px;}
.chat-close-btn{background:none;border:none;cursor:pointer;color:var(--dim);font-size:15px;padding:2px;transition:color .15s;line-height:1;}
.chat-close-btn:hover{color:var(--text);}
#chat-msgs{flex:1;overflow-y:auto;padding:10px 12px;display:flex;flex-direction:column;gap:5px;}
#chat-msgs::-webkit-scrollbar{width:3px;}
#chat-msgs::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
.chat-msg{display:flex;flex-direction:column;gap:1px;animation:msgIn .18s ease both;}
@keyframes msgIn{from{opacity:0;transform:translateY(3px);}to{opacity:1;transform:none;}}
.chat-msg-head{display:flex;align-items:baseline;gap:6px;}
.chat-msg-user{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;color:var(--a2);}
.chat-msg-user.admin{color:#f59e0b;}
.chat-msg-time{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--dim);}
.chat-msg-text{font-size:12px;color:var(--text);line-height:1.4;word-break:break-word;padding-left:2px;}
.chat-msg.announce{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:8px;padding:6px 10px;margin:2px 0;}
.chat-msg-sys{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);text-align:center;padding:2px 0;letter-spacing:.5px;}
#chat-input-row{padding:9px 12px;border-top:1px solid var(--border);display:flex;gap:7px;flex-shrink:0;}
#chat-input{flex:1;background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:7px 11px;border-radius:9px;outline:none;transition:border-color .2s;}
#chat-input:focus{border-color:var(--a);}
#chat-input::placeholder{color:var(--dim);}
#chat-input:disabled{opacity:.5;}
#chat-send{background:var(--a);border:none;color:#fff;font-family:'JetBrains Mono',monospace;font-size:11px;padding:7px 14px;border-radius:9px;cursor:pointer;transition:opacity .15s;flex-shrink:0;}
#chat-send:hover{opacity:.85;}
#chat-send:disabled{opacity:.4;cursor:default;}
#admin-bar{padding:8px 12px;border-top:1px solid rgba(245,158,11,.25);background:rgba(245,158,11,.05);display:none;flex-direction:column;gap:6px;flex-shrink:0;}
#admin-bar.show{display:flex;}
#announce-input{width:100%;background:var(--bg);border:1px solid rgba(245,158,11,.3);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:7px 11px;border-radius:9px;outline:none;}
#announce-input:focus{border-color:#f59e0b;}
#announce-input::placeholder{color:rgba(245,158,11,.35);}
#announce-send{background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#000;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;padding:7px 14px;border-radius:9px;cursor:pointer;letter-spacing:.5px;width:100%;transition:opacity .15s;}
#announce-send:hover{opacity:.85;}


/* ── INLINE GAME VIEWER ── */
#game-viewer{
  position:fixed;inset:0;z-index:8000;
  background:#000;display:none;flex-direction:column;
}
#game-viewer.open{display:flex;}
#game-viewer-bar{
  background:rgba(5,5,10,.97);border-bottom:1px solid var(--border);
